    <!-- Графики -->
    <ControlTemplate
    x:Key="GraphicIcon">
        <Viewbox
        Stretch="Uniform"
        Margin="2,0,0,0">
        <Grid> 
            <Path
            Data="M2 22h21v1H1V1h1zm8.613-3.193L14.61 5.793l3.87 8.956 3.726-6.35-.862-.506-2.728 4.649-4.165-9.637-4.097 13.338-3.877-7.108L2.9 16.552l.9.435 2.732-5.664z"
            Fill="{TemplateBinding ContentControl.Foreground}"/>
            <Path
            Data="M0 0h24v24H0z"
            Stroke="{TemplateBinding ContentControl.Foreground}"/> 
        </Grid> 
        </Viewbox>
    </ControlTemplate>
     
    <!--
    Иконка дискеты.
    -->
    <ControlTemplate
        x:Key="SaveIcon"> 
         <Viewbox
            ClipToBounds="False" Stretch="UniformToFill"> 
                <Path
                Data="M18.1716 1C18.702 1 19.2107 1.21071 19.5858 1.58579L22.4142 4.41421C22.7893 4.78929 23 5.29799 23 5.82843V20C23 21.6569 21.6569 23 20 23H4C2.34315 23 1 21.6569 1 20V4C1 2.34315 2.34315 1 4 1H18.1716ZM4 3C3.44772 3 3 3.44772 3 4V20C3 20.5523 3.44772 21 4 21L5 21L5 15C5 13.3431 6.34315 12 8 12L16 12C17.6569 12 19 13.3431 19 15V21H20C20.5523 21 21 20.5523 21 20V6.82843C21 6.29799 20.7893 5.78929 20.4142 5.41421L18.5858 3.58579C18.2107 3.21071 17.702 3 17.1716 3H17V5C17 6.65685 15.6569 8 14 8H10C8.34315 8 7 6.65685 7 5V3H4ZM17 21V15C17 14.4477 16.5523 14 16 14L8 14C7.44772 14 7 14.4477 7 15L7 21L17 21ZM9 3H15V5C15 5.55228 14.5523 6 14 6H10C9.44772 6 9 5.55228 9 5V3Z"
                Fill="{TemplateBinding ContentControl.Foreground}"/> 
        </Viewbox>
    </ControlTemplate> 
    
    <!--
    Иконка стрелочки назад.
    -->
    <ControlTemplate
        x:Key="UndoIcon"> 
         <Viewbox
            ClipToBounds="False" Stretch="UniformToFill">
            <Grid>
                
                <Path
                Data="M10 21.4199H15C16.8565 21.4199 18.637 20.6824 19.9497 19.3696C21.2625 18.0569 22 16.2764 22 14.4199C22 12.5634 21.2625 10.783 19.9497 9.47021C18.637 8.15746 16.8565 7.41992 15 7.41992H2"
                Stroke="{TemplateBinding ContentControl.Foreground}"
                StrokeJoin="Round"
                StrokeLineCap="Round"
                StrokeThickness="1.5"/> 

                <Path
                Data="M6 11.4199L2 7.41992L6 3.41992"
                Stroke="{TemplateBinding ContentControl.Foreground}"
                StrokeJoin="Round"
                StrokeLineCap="Round"
                StrokeThickness="1.5"/> 
            </Grid> 
        </Viewbox>
    </ControlTemplate> 
    
    <!--
    Иконка стрелочки вперед.
    -->
    <ControlTemplate
        x:Key="RedoIcon"> 
         <Viewbox
            ClipToBounds="False" Stretch="UniformToFill"
            Margin="1,0,0,0"> 
                <ContentControl
                Template="{StaticResource UndoIcon}">
                  <ContentControl.RenderTransform>
                    <ScaleTransform ScaleX="-1" ScaleY="1" />
                  </ContentControl.RenderTransform>
                </ContentControl>
        </Viewbox>
    </ControlTemplate> 
    
    <!--
    Иконка двух одинаковых объектов.
    -->
    <ControlTemplate
        x:Key="DuplicateIcon"> 
         <Viewbox
            ClipToBounds="False" Stretch="UniformToFill"> 
                <Path
                Data="M36,12V6a2,2,0,0,0-2-2H6A2,2,0,0,0,4,6V34a2,2,0,0,0,2,2h6v6a2,2,0,0,0,2,2H42a2,2,0,0,0,2-2V14a2,2,0,0,0-2-2ZM8,32V8H32V32Zm32,8H16V36H34a2,2,0,0,0,2-2V16h4Z"
                Stroke="{TemplateBinding ContentControl.Foreground}" 
                StrokeJoin="Round"
                StrokeLineCap="Round"
                StrokeThickness="2"/>  
        </Viewbox>
    </ControlTemplate> 
     
</ResourceDictionary>
