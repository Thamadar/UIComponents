<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             
             xmlns:local="using:Client.Avalonia.Views.Tabs.Geometry.Tools"
             xmlns:uic="using:Lib.Avalonia.Controls"
             xmlns:uiconv="using:Lib.Avalonia.Converters"
             xmlns:shapes="using:Client.Avalonia.Views.Geometry.Shapes" 
              
             x:DataType="local:BaseTool" 
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="100"
             x:Class="Client.Avalonia.Views.Tabs.Geometry.Tools.ToolEditView">
              
    <Design.DataContext>
        <local:ShapeCircleEditViewModel />
    </Design.DataContext> 
     
    <Panel  
    Background="{StaticResource PrimaryGraySmoke}">
        <ContentControl  
            Margin="12,0" 
            Content="{Binding CurrentToolEditVM}"/>
    </Panel>   
</UserControl>
