<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       
        xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Xaml.Behaviors.Interactivity"
        xmlns:uibehaviors="using:Lib.Avalonia.Behaviors"    
        xmlns:views="using:Client.Avalonia.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:DataType="views:MainWindowViewModel"
        x:Class="Client.Avalonia.MainWindowView"
        Focusable="True"
        Background="White"
        Title="UIComponents">

    <Design.DataContext>
        <views:MainWindowViewModel />
    </Design.DataContext>
     
    <i:Interaction.Behaviors>
        <uibehaviors:AddWindowHotKeysBehavior HotKeys="{Binding HotKeys}"/>
    </i:Interaction.Behaviors>
    
    <!-- TO DO:Вкладки разных областей. Например: Geometry, Graphs, ...-->
    <views:GeometryView DataContext="{Binding GeometryViewModel}"/>
</Window>
