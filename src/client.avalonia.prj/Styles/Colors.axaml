<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="CanvasEmptyBackgroundColor">#262626</Color>

    <SolidColorBrush
    x:Key="CanvasEmptyBackground"
    Color="{StaticResource CanvasEmptyBackgroundColor}" /> 

</ResourceDictionary>
