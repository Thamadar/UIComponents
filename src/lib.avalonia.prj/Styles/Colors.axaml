<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="SliderTrackFillColor">#8eaac1</Color>
    <Color x:Key="SliderTrackFillPointerOverColor">#8eaac1</Color>
    <Color x:Key="SliderTrackFillPressedColor">#8eaac1</Color> 
    
    <Color x:Key="PrimaryGrayColor">#383838</Color>
    <Color x:Key="PrimaryGrayLightColor">#454545</Color>
    <Color x:Key="PrimaryGrayDarkColor">#262626</Color>
    <Color x:Key="PrimaryGraySmokeColor">#494949</Color>

    <Color x:Key="PrimaryDarkColor">#2e2e2e</Color>

    <Color x:Key="PrimaryWhiteColor">#e1e1e1</Color>  
    
    <Color x:Key="SeparatorMenuDarkColor">#2e2e2e</Color>
    <Color x:Key="SeparatorMenuColor">#494949</Color>

       <!-- MessageBox -->
    <Color x:Key="MessageBoxHeaderForegroundColor">#e1e1e1</Color>
    <Color x:Key="MessageBoxTextForegroundColor">#e1e1e1</Color>
    <Color x:Key="MessageBoxBackgroundColor">#383838</Color> 
    <Color x:Key="DialogDarkControlBackgroundColor">#1E2023</Color>

    <!-- Цвета слайдера -->
    <SolidColorBrush
    x:Key="SliderTrackFill"
    Color="{StaticResource SliderTrackFillColor}" /> 
    <SolidColorBrush
    x:Key="SliderTrackFillPointerOver"
    Color="{StaticResource SliderTrackFillPointerOverColor}" />
    <SolidColorBrush
    x:Key="SliderTrackFillPressed"
    Color="{StaticResource SliderTrackFillPressedColor}" />
     
    <!-- Главные цвета приложения -->
    <SolidColorBrush
    x:Key="PrimaryGray"
    Color="{StaticResource PrimaryGrayColor}" />
    <SolidColorBrush
    x:Key="PrimaryGrayLight"
    Color="{StaticResource PrimaryGrayLightColor}" />
    <SolidColorBrush
    x:Key="PrimaryGrayDark"
    Color="{StaticResource PrimaryGrayDarkColor}" />
    <SolidColorBrush
    x:Key="PrimaryDark"
    Color="{StaticResource PrimaryDarkColor}" />
    <SolidColorBrush
    x:Key="PrimaryWhite"
    Color="{StaticResource PrimaryWhiteColor}" />
    <SolidColorBrush
    x:Key="PrimaryGraySmoke"
    Color="{StaticResource PrimaryGraySmokeColor}" />
     
    <SolidColorBrush
    x:Key="SeparatorMenu"
    Color="{StaticResource SeparatorMenuColor}" />
    <SolidColorBrush
    x:Key="SeparatorMenuDark"
    Color="{StaticResource SeparatorMenuDarkColor}" />
     
     
 
    <SolidColorBrush
        x:Key="MessageBoxHeaderForeground"
        Color="{StaticResource MessageBoxHeaderForegroundColor}" />
    <SolidColorBrush
        x:Key="MessageBoxTextForeground"
        Color="{StaticResource MessageBoxTextForegroundColor}" />
    <SolidColorBrush
        x:Key="MessageBoxBackground"
        Color="{StaticResource MessageBoxBackgroundColor}" />
        
    <SolidColorBrush
        x:Key="DialogDarkControlBackground"
        Color="{StaticResource DialogDarkControlBackgroundColor}" />
</ResourceDictionary>
