<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <Border Padding="20">
    <TextBlock Text="55555"
    Classes="default menu"/>
    </Border>
  </Design.PreviewWith>

    <Style Selector="TextElement">
        <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}" />
    </Style>

    <Style Selector="TextBlock"> 
        <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{DynamicResource NormalFontSize}" /> 
    </Style> 
     
    <Style Selector="TextBlock.message-box-header">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,8" />
        <Setter Property="FontSize" Value="{DynamicResource MediumFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource MessageBoxHeaderForeground}" />
    </Style>

    <Style Selector="TextBlock.message-box-message">
        <Setter Property="IsVisible" Value="{Binding Message.Length}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="32,0,32,8" />
        <Setter Property="Foreground" Value="{DynamicResource MessageBoxTextForeground}" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="WordEllipsis" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.default">
        <Style Selector="^ TextElement">
            <Setter Property="Foreground" Value="{StaticResource PrimaryWhite}" />
        </Style>
        <Setter Property="Foreground" Value="{StaticResource PrimaryWhite}" />

        <Setter Property="Padding" Value="4,7,4,4" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        
        <Style Selector="^.menu">
            <Setter Property="Padding" Value="0,7,4,4" /> 
        </Style>
        <Style Selector="^.normal">
            <Setter Property="FontWeight" Value="Regular" /> 
        </Style>
        <Style Selector="^.medium">
            <Setter Property="FontWeight" Value="Regular" /> 
            <Setter Property="FontSize" Value="{DynamicResource MediumFontSize}" />
        </Style>
    </Style>

</Styles>
