<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <Border Padding="20">
        <Slider Width="500"/>
    </Border>
  </Design.PreviewWith>

    <Style Selector="Slider">
        <Setter Property="Cursor" Value="Hand"/> 
    </Style>
</Styles>
